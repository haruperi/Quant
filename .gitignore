# API keys and secrets
.secrets
secrets.json
api_keys.json

# Large exports
*.pdf
*.html
!docs/**/*.html
!templates/**/*.html

# Job queue files
job_queue/
worker_state/
.mypy_cache/
.dmypy.json
dmypy.json

